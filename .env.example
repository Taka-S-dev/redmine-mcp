# Redmine の URL（末尾スラッシュなし）
REDMINE_URL=https://redmine.example.com

# Redmine の API キー
# 取得方法: Redmine にログイン → 個人設定 → 右側の「API アクセスキー」→「表示」
REDMINE_API_KEY=your_api_key_here

# 任意: タイムアウト（ミリ秒、デフォルト 30000）
# REDMINE_TIMEOUT_MS=30000

# 任意: プロジェクトスコープ（厳格モード）。
# カンマ区切りで identifier を列挙すると、以下が有効になる：
#   - describe_schema / list_projects はここに列挙したプロジェクトだけ表示
#   - スコープ外を project 引数で指定するとツールはエラー
#   - project 省略時は列挙したプロジェクト全てに並列問い合わせ（fan-out）
# 「会社の大量プロジェクトの中から特定だけを対象にしたい」用途に使う。
# REDMINE_PROJECTS=my-product,my-product-mobile

# 任意: 社内 CA 証明書のパス（PEM 形式）。
# 推奨パターン: 証明書を certs/ ディレクトリに置いて相対パスで指定する。
# 詳細は certs/README.md 参照。
# NODE_EXTRA_CA_CERTS=certs/company-ca.pem
